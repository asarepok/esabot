# Application environment
# development | testing | production
ENVIRONMENT=development

# Telegram update mode
# polling | webhook
BOT_MODE=polling

# Telegram bot token
BOT_TOKEN=

# Main administrator's Telegram chat ID
ROOT_USER_ID=

# Database connection URL
# Development:
# DATABASE_URL=sqlite://db.sqlite3
# Production:
# DATABASE_URL=postgres://user:password@host:5432/esabot
DATABASE_URL=sqlite://db.sqlite3

# Telegram webhook configuration
# Only required when BOT_MODE=webhook
WEBHOOK_URL=
WEBHOOK_SECRET=

# Logging
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO